{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/favicon\.ico$",
      "dest": "/favicon.ico"
    },
    {
      "src": "^/_expo/(.*)$",
      "dest": "/_expo/$1"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/manifest\.json$",
      "dest": "/manifest.json"
    },
    {
      "src": "^/sw\.js$",
      "dest": "/sw.js"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}
